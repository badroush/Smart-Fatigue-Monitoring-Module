# Port HTTP (frontend: REACT_APP_API_BASE_URL=http://127.0.0.1:3000/api)
PORT=3000

# MySQL (même logique que Symfony DATABASE_URL)
# Exemple : mysql://app:secret@127.0.0.1:3306/sfam
DATABASE_URL=

# Clé dashboard (header X-API-KEY) — accès complet siège (équivalent admin) si pas de JWT
# Même clé en query : GET /api/alerts/stream?api_key=... (flux SSE)
# Avec login/mot de passe, le frontend envoie Authorization: Bearer <JWT> et n’a pas besoin de cette clé.
SUPERVISOR_API_KEY=sfam_superviseur_secret_2026

# JWT pour les comptes dashboard (POST /api/auth/login)
JWT_SECRET=changez-moi-en-production-long-et-aleatoire

# Optionnel : connexion sans Firestore (dev uniquement). Ne pas activer en production.
# ALLOW_ENV_DASHBOARD_LOGIN=1
# SFAM_ADMIN_LOGIN=admin
# SFAM_ADMIN_PASSWORD=
# SFAM_SUPERVISEUR_LOGIN=superviseur
# SFAM_SUPERVISEUR_PASSWORD=

# Data provider:
# - mysql        : tout en MySQL (dev)
# - firestore    : siège / dashboard sans connexion au MySQL véhicule (lecture cloud uniquement)
# - dual         : véhicule / edge : MySQL local + réplication Firestore + file d'attente
DATA_PROVIDER=mysql

# Firebase Admin (requis si DATA_PROVIDER=firestore)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_SERVICE_ACCOUNT_PATH=C:\\path\\to\\serviceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# File d'attente MySQL → Firestore (mode dual) : intervalle de sync automatique (ms)
# FIRESTORE_OUTBOX_INTERVAL_MS=30000

# Test dashboard sans MySQL alors que DATABASE_URL est encore défini (lectures = Firestore)
# FORCE_FIRESTORE_READS=1
